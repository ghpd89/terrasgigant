---
import Layout from '../layouts/Layout.astro';
import StickyBuyBar from '../components/StickyBuyBar.astro';

const faqItems = [
  { q: 'Zijn kunststof terrasmeubelen goed?', a: 'Kunststof (ook: HDPE-kunststof of "hardhout-look") terrasmeubelen zijn uitstekend voor wie een onderhoudsvrije set zoekt. Ze rotten niet, roesten niet, en hoeven nooit behandeld te worden. Wel minder edel van uiterlijk dan teak of aluminium.' },
  { q: 'Wat is het verschil tussen gewone kunststof en HDPE kunststof?', a: 'Gewone kunststof (goedkoop) verkleurt en wordt brokkelig na 3–5 jaar UV-blootstelling. HDPE (High Density Polyethylene) kunststof is UV-gestabiliseerd, recyclebaar en gaat 25+ jaar mee. Brands als Lifetime en Keter gebruiken HDPE.' },
  { q: 'Gaat kunststof terrasmeubels mee in de winter buiten?', a: 'Ja — kunststof meubelen kunnen prima buiten blijven in de winter. Ze zijn vorstbestendig en waterproof. Optioneel kun je ze afdekken met een hoes, maar strikt noodzakelijk is het niet.' },
  { q: 'Hoeveel kost kunststof terrasmeubilair?', a: 'Budget: €99–299 (gewone kunststof, Intratuin, IKEA). Midrange HDPE: €299–699 (Lifetime, Keter). Premium: €699–1.200 (gevlochten polyrattan-look HDPE, Hartman).' },
];

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "BreadcrumbList", "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.terrasgigant.nl" },
      { "@type": "ListItem", "position": 2, "name": "Kunststof terrasmeubelen", "item": "https://www.terrasgigant.nl/kunststof-terrasmeubelen" }
    ]},
    { "@type": "FAQPage", "mainEntity": faqItems.map(({ q, a }) => ({ "@type": "Question", "name": q, "acceptedAnswer": { "@type": "Answer", "text": a } })) }
  ]
});
---

<Layout
  title="Kunststof terrasmeubelen — voordelen, nadelen & beste merken 2026 | Terrasgigant.nl"
  description="Kunststof terrasmeubelen kopen? Alles over HDPE kunststof, voor- en nadelen, en de beste sets van Lifetime, Keter en Hartman."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={structuredData} />
  </Fragment>

  <div class="max-w-5xl mx-auto px-4 py-10">
    <nav class="text-sm text-slate-500 mb-6 flex gap-2 flex-wrap">
      <a href="/" class="hover:text-green-600">Home</a><span>›</span>
      <span class="text-slate-700">Kunststof terrasmeubelen</span>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mb-3">Kunststof terrasmeubelen</h1>
    <p class="text-slate-600 text-lg mb-8 max-w-2xl">100% onderhoudsvrij, vorstbestendig en recyclebaar. Kunststof meubelen zijn de meest onderhoudsvriendelijke keuze.</p>

    <!-- Voordelen/nadelen -->
    <div class="mb-10 grid sm:grid-cols-2 gap-4">
      <div class="bg-green-50 border border-green-200 rounded-2xl p-5">
        <div class="font-bold text-green-800 mb-3">✓ Voordelen kunststof</div>
        <ul class="space-y-1.5 text-sm text-slate-700">
          {[
            '100% onderhoudsvrij — nooit oliën of schilderen',
            'Waterproof + vorstbestendig',
            'Lichtgewicht en makkelijk te verplaatsen',
            'Goedkoper dan teak of aluminium',
            'HDPE-types: 25+ jaar levensduur',
            'Recyclebaar aan einde levensduur',
          ].map(v => <li class="flex gap-2"><span class="text-green-500 shrink-0">✓</span>{v}</li>)}
        </ul>
      </div>
      <div class="bg-red-50 border border-red-200 rounded-2xl p-5">
        <div class="font-bold text-red-800 mb-3">✗ Nadelen kunststof</div>
        <ul class="space-y-1.5 text-sm text-slate-700">
          {[
            'Minder edel uiterlijk dan teak of aluminium',
            'Goedkope types verkleuren na 3–5 jaar',
            'Warm aanvoelen bij veel zon',
            'Niet onbeperkt aanpasbaar (kleur/vorm)',
            'Goedkope types minder stabiel/stevig',
          ].map(v => <li class="flex gap-2"><span class="text-red-400 shrink-0">✗</span>{v}</li>)}
        </ul>
      </div>
    </div>

    <!-- HDPE uitleg -->
    <div class="mb-10 bg-slate-50 border border-slate-200 rounded-2xl p-6">
      <h2 class="text-lg font-bold text-slate-900 mb-2">💡 Gewone kunststof vs. HDPE kunststof</h2>
      <div class="grid sm:grid-cols-2 gap-4 text-sm">
        <div class="bg-white rounded-xl border border-red-100 p-4">
          <div class="font-bold text-red-700 mb-2">Goedkoop kunststof (PP/PE)</div>
          <ul class="space-y-1 text-slate-600">
            <li>• Verkleurt geel/grijs na 3–5 jaar</li>
            <li>• Brokkelt bij vorst</li>
            <li>• Lichtgewicht = instabiel</li>
            <li>• Levensduur: 3–8 jaar</li>
          </ul>
        </div>
        <div class="bg-white rounded-xl border border-green-100 p-4">
          <div class="font-bold text-green-700 mb-2">HDPE kunststof (premium)</div>
          <ul class="space-y-1 text-slate-600">
            <li>• UV-gestabiliseerd: blijft kleurecht</li>
            <li>• Vorstbestendig tot -40°C</li>
            <li>• Zwaarder = stabiel</li>
            <li>• Levensduur: 25+ jaar</li>
            <li>• 100% recyclebaar</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Picks -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-slate-900 mb-5">Beste kunststof terrasmeubelen per budget</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          { tag: 'Budget', tagColor: 'slate', label: 'Instapklasse', beschrijving: 'IKEA TÄRNÖ, Intratuin wit kunststof of Keter-instapmodellen. Goed voor balkon of seizoensgebruik. 4–8 jaar.', bol: 'kunststof tuinset budget wit', cb: 'kunststof tuinstoel wit budget' },
          { tag: 'Beste keuze', tagColor: 'green', label: 'HDPE Midrange', beschrijving: 'Lifetime 6-delig of Keter Corfu HDPE-sets. UV-gestabiliseerd HDPE, 10-jaarsgarantie, lichtgewicht maar stabiel. 15–20 jaar.', bol: 'hdpe kunststof tuinset lifetime keter', cb: 'kunststof tuinset hdpe' },
          { tag: 'Premium', tagColor: 'amber', label: 'Design HDPE', beschrijving: 'Hartman Sophie Rondo polyrattan-look of Manutti Polyx — HDPE met weven, ziet er uit als polyrattan maar is volledig onderhoudsvrij en duurzamer.', bol: 'hartman sophie rondo hdpe loungesets', cb: 'kunststof loungestel premium hartman' },
        ].map(({ tag, tagColor, label, beschrijving, bol, cb }) => {
          const bc = tagColor === 'green' ? 'border-green-400 bg-green-50' : tagColor === 'amber' ? 'border-amber-400 bg-amber-50' : 'border-slate-200 bg-white';
          const tc = tagColor === 'green' ? 'text-green-700' : tagColor === 'amber' ? 'text-amber-700' : 'text-slate-500';
          return (
            <div class={`rounded-2xl border-2 p-5 flex flex-col ${bc}`}>
              <div class={`text-xs font-bold uppercase tracking-wide mb-1 ${tc}`}>{tag}</div>
              <div class="font-black text-slate-900 text-lg mb-2">{label}</div>
              <p class="text-xs text-slate-600 leading-relaxed mb-4 flex-1">{beschrijving}</p>
              <div class="space-y-2">
                <a href={`https://www.bol.com/nl/nl/s/?searchtext=${bol}`} target="_blank" rel="noopener nofollow" class="flex justify-between bg-orange-500 hover:bg-orange-600 text-white text-xs font-bold py-2 px-3 rounded-lg transition-colors"><span>Bol.com</span><span>→</span></a>
                <a href={`https://www.coolblue.nl/zoeken?query=${cb}`} target="_blank" rel="noopener nofollow" class="flex justify-between bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2 px-3 rounded-lg transition-colors"><span>Coolblue</span><span>→</span></a>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="mb-12 prose prose-slate max-w-none">
      <h2>Kunststof vs aluminium: wat kies je?</h2>
      <p>Kies <strong>kunststof</strong> als je absoluut geen onderhoud wilt, een laag budget hebt, of meubels makkelijk wilt verplaatsen (camping, balkon, kleine tuin).</p>
      <p>Kies <strong>aluminium</strong> als je meer designvrijheid wilt, een robuuster, edeler gevoel prefereert, en bereid bent iets meer te betalen voor een set die er over 15 jaar nog net zo goed uitziet.</p>
      <p><strong>HDPE-kunststof</strong> is de uitzondering: even duurzaam als aluminium, 100% onderhoudsvrij, maar met beperkter designaanbod. Perfect voor wie zero-maintenance bovenaan heeft staan.</p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-slate-900 mb-5">Veelgestelde vragen kunststof terrasmeubelen</h2>
      <div class="space-y-2">
        {faqItems.map(({ q, a }) => (
          <details class="group border border-slate-200 rounded-xl bg-white overflow-hidden">
            <summary class="flex items-center justify-between px-5 py-4 font-semibold text-slate-900 cursor-pointer list-none hover:bg-slate-50 transition-colors">
              <span class="pr-4 text-sm">{q}</span>
              <span class="text-slate-300 group-open:text-green-500 text-xl leading-none shrink-0"><span class="group-open:hidden">+</span><span class="hidden group-open:inline">−</span></span>
            </summary>
            <div class="px-5 pb-4 pt-0 text-slate-600 text-sm leading-relaxed border-t border-slate-100">{a}</div>
          </details>
        ))}
      </div>
    </section>

    <section class="border-t border-slate-200 pt-8">
      <div class="flex flex-wrap gap-3">
        <a href="/aluminium-terrasmeubelen" class="border border-slate-200 bg-white hover:border-green-400 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 transition-colors">Aluminium meubelen →</a>
        <a href="/polyrattan-terrasmeubelen" class="border border-slate-200 bg-white hover:border-green-400 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 transition-colors">Polyrattan →</a>
        <a href="/terrasmeubelen-kopen-gids" class="border border-slate-200 bg-white hover:border-green-400 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 transition-colors">Koopgids →</a>
      </div>
    </section>
  </div>

  <StickyBuyBar
    label="Kunststof terrasmeubelen"
    bolUrl="https://www.bol.com/nl/nl/s/?searchtext=kunststof+terrasmeubelen+hdpe"
    coolblueUrl="https://www.coolblue.nl/zoeken?query=kunststof+terrasmeubelen"
  />
</Layout>
