---
import Layout from '../layouts/Layout.astro';
import StickyBuyBar from '../components/StickyBuyBar.astro';

const faqItems = [
  { q: 'Wat is het verschil tussen een zweefparasol en een kantelparasol?', a: 'Een zweefparasol heeft de paal aan de zijkant (geen centrale paal), waardoor je vrij zit zonder obstakel. Je kunt hem 360° draaien. Een kantelparasol heeft de paal in het midden maar kan kantelen. Zweefparasols zijn duurder maar veel praktischer.' },
  { q: 'Welke maat zweefparasol heb ik nodig?', a: 'Voor een loungestel: 300×300 cm (9m²). Voor een tuintafel 6p: 350×350 cm. Vuistregel: neem parasol die 60–80 cm aan alle kanten uitsteekt voorbij het meubelstuk.' },
  { q: 'Wat kost een goede zweefparasol?', a: 'Budget (<€200): Lidl, Action — kunststof frame, 2–4 jaar. Midrange (€200–500): Doppler, Garden Plus — aluminium, Olefin doek, 8–15 jaar. Premium (€500–1200): Glatz, Sombrano — 100% Sunbrella, 5-jaarsgarantie op doek, 20+ jaar.' },
  { q: 'Hoe zet je een zweefparasol neer?', a: 'Zweefparasols hebben een zware verzwaarde voet nodig: minimaal 50–80 kg (op steen) of beton-/grondveranker. NOOIT met een lichte voet van <40 kg — gevaarlijk bij wind!' },
  { q: 'Welke zweefparasol is het beste?', a: 'Beste allround: Glatz Sombrano (luxe) of Doppler Expert (prijs-kwaliteit). Voor budget: Sunred Chester. De Doppler Expert-lijn scoort het beste in het €300–500 segment: stevig aluminium frame, gepatenteerde spanning van het doek.' },
];

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "BreadcrumbList", "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.terrasgigant.nl" },
      { "@type": "ListItem", "position": 2, "name": "Beste parasol", "item": "https://www.terrasgigant.nl/beste-parasol" },
      { "@type": "ListItem", "position": 3, "name": "Zweefparasol", "item": "https://www.terrasgigant.nl/zweefparasol" }
    ]},
    { "@type": "FAQPage", "mainEntity": faqItems.map(({ q, a }) => ({ "@type": "Question", "name": q, "acceptedAnswer": { "@type": "Answer", "text": a } })) }
  ]
});
---

<Layout
  title="Beste zweefparasol kopen 2026 — vergelijk maten & merken | Terrasgigant.nl"
  description="De beste zweefparasol kopen? Vergelijk Glatz, Doppler en Sunred zweefparasols — compleet advies over maten, voet en doekmateriaal."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={structuredData} />
  </Fragment>

  <div class="max-w-5xl mx-auto px-4 py-10">
    <nav class="text-sm text-slate-500 mb-6 flex gap-2 flex-wrap">
      <a href="/" class="hover:text-green-600">Home</a><span>›</span>
      <a href="/beste-parasol" class="hover:text-green-600">Beste parasol</a><span>›</span>
      <span class="text-slate-700">Zweefparasol</span>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mb-3">Beste zweefparasol kopen</h1>
    <p class="text-slate-600 text-lg mb-8 max-w-2xl">Zonder centrale paal, 360° draaibaar, perfect voor loungesets en grote tuintafels. Alles over zweefparasols.</p>

    <!-- Voordelen vs nadelen -->
    <div class="mb-8 grid sm:grid-cols-2 gap-4">
      <div class="bg-green-50 border border-green-200 rounded-2xl p-5">
        <div class="font-bold text-green-800 mb-3">✓ Voordelen zweefparasol</div>
        <ul class="space-y-1.5 text-sm text-slate-700">
          {['Geen centrale paal — vrij instappen', '360° draaibaar — zon altijd goed', 'Grote oppervlakte (3×3 tot 4×4m)', 'Kantelbaar voor lage zon', 'Ideaal boven loungesets'].map(v => (
            <li class="flex gap-2"><span class="text-green-500 shrink-0">✓</span>{v}</li>
          ))}
        </ul>
      </div>
      <div class="bg-red-50 border border-red-200 rounded-2xl p-5">
        <div class="font-bold text-red-800 mb-3">✗ Nadelen zweefparasol</div>
        <ul class="space-y-1.5 text-sm text-slate-700">
          {['Duurder dan stokparasol', 'Zware voet nodig (50–80 kg)', 'Meer ruimte aan één zijde nodig', 'Complexer mechanisme', 'Minder stabiel bij harde wind'].map(v => (
            <li class="flex gap-2"><span class="text-red-400 shrink-0">✗</span>{v}</li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Maatgids -->
    <div class="mb-10 bg-blue-50 border border-blue-200 rounded-2xl p-5">
      <h2 class="font-bold text-slate-900 mb-3">📐 Welke maat zweefparasol heb ik nodig?</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead><tr class="bg-blue-100 text-slate-700">
            <th class="text-left px-3 py-2 rounded-tl-lg font-semibold">Gebruik</th>
            <th class="px-3 py-2 font-semibold">Aanbevolen maat</th>
            <th class="text-right px-3 py-2 rounded-tr-lg font-semibold">Voet gewicht</th>
          </tr></thead>
          <tbody class="divide-y divide-blue-100">
            {[
              ['Loungestel 4-delig', '300×300 cm', '50–60 kg'],
              ['Tuinset 4 personen', '250×250 cm', '40–50 kg'],
              ['Tuinset 6 personen', '350×350 cm', '65–80 kg'],
              ['Groot loungeset 6-delig', '400×300 cm', '70–90 kg'],
            ].map(([gebruik, maat, voet]) => (
              <tr class="bg-white hover:bg-blue-50/50 transition-colors">
                <td class="px-3 py-2.5 font-medium text-slate-800">{gebruik}</td>
                <td class="px-3 py-2.5 text-center font-black text-slate-900">{maat}</td>
                <td class="px-3 py-2.5 text-right text-slate-600">{voet}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Picks per budget -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-slate-900 mb-5">Beste zweefparasols per budget</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          {
            tag: '< €200', tagColor: 'slate', label: 'Budget',
            naam: 'Garden Select / Sunred Chester',
            spec: '3×3m, aluminium paal, polyester doek',
            voor: 'Incidenteel gebruik, balkon of kleine tuin. 3–5 jaar mee.',
            bol: 'zweefparasol aluminium budget', cb: 'zweefparasol budget'
          },
          {
            tag: 'Beste keuze', tagColor: 'green', label: 'Midrange',
            naam: 'Doppler Expert 3.5m',
            spec: '350×350 cm, aluminium, Olefin UV50+ doek',
            voor: 'De sweet spot. Doppler\'s gepatenteerde spansysteem zorgt dat het doek altijd strak staat. 10–15 jaar mee.',
            bol: 'doppler zweefparasol expert', cb: 'zweefparasol doppler expert'
          },
          {
            tag: '€600–1200', tagColor: 'amber', label: 'Premium',
            naam: 'Glatz Sombrano',
            spec: '3–4m, gepolijst aluminium, Sunbrella doek',
            voor: '5 jaar garantie op doek, 3mm aluminium frame, ingebouwde LED verlichting optioneel. Eenmalig investeren.',
            bol: 'glatz zweefparasol sombrano', cb: 'zweefparasol glatz premium'
          },
        ].map(({ tag, tagColor, label, naam, spec, voor, bol, cb }) => {
          const bc = tagColor === 'green' ? 'border-green-400 bg-green-50' : tagColor === 'amber' ? 'border-amber-400 bg-amber-50' : 'border-slate-200 bg-white';
          const tc = tagColor === 'green' ? 'text-green-700' : tagColor === 'amber' ? 'text-amber-700' : 'text-slate-500';
          return (
            <div class={`rounded-2xl border-2 p-5 flex flex-col ${bc}`}>
              <div class={`text-xs font-bold uppercase tracking-wide mb-1 ${tc}`}>{tag}</div>
              <div class="font-black text-slate-900 text-lg mb-0.5">{label}</div>
              <div class="text-xs font-semibold text-slate-600 mb-1">{naam}</div>
              <div class="text-xs text-slate-500 mb-2">{spec}</div>
              <p class="text-xs text-slate-600 leading-relaxed mb-4 flex-1">{voor}</p>
              <div class="space-y-2">
                <a href={`https://www.bol.com/nl/nl/s/?searchtext=${bol}`} target="_blank" rel="noopener nofollow" class="flex justify-between bg-orange-500 hover:bg-orange-600 text-white text-xs font-bold py-2 px-3 rounded-lg transition-colors"><span>Bol.com</span><span>→</span></a>
                <a href={`https://www.coolblue.nl/zoeken?query=${cb}`} target="_blank" rel="noopener nofollow" class="flex justify-between bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2 px-3 rounded-lg transition-colors"><span>Coolblue</span><span>→</span></a>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Voet -->
    <section class="mb-10 bg-amber-50 border border-amber-200 rounded-2xl p-6">
      <h2 class="text-xl font-bold text-slate-900 mb-2">⚠️ Zware voet: niet overslaan</h2>
      <p class="text-sm text-slate-700 mb-3">De meeste zweefparasol-ongelukken zijn het gevolg van een te lichte voet. Bij windstoten van ≥ Beaufort 3 kan een zweefparasol met lichte voet omvallen.</p>
      <div class="grid sm:grid-cols-3 gap-3 text-sm">
        {[
          { type: 'Grondplaat 40–50 kg', check: '⚠️', omschrijving: 'Enkel voldoende voor parasols tot 250cm. Niet aanbevolen voor grotere zweefparasols.' },
          { type: 'Tegellast 60–80 kg', check: '✓', omschrijving: 'Standaard voor de meeste zweefparasols. Vul met betontegels of koop een gedekte voet.' },
          { type: 'Grondanker / beton', check: '🏆', omschrijving: 'Meest stabiel. Betoneer de voetpaal in een emmer of beton in terras. Permanent maar maximaal veilig.' },
        ].map(({ type, check, omschrijving }) => (
          <div class="bg-white rounded-xl p-3 border border-amber-100">
            <div class="font-bold text-slate-800 mb-1">{check} {type}</div>
            <p class="text-xs text-slate-600">{omschrijving}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12 prose prose-slate max-w-none">
      <h2>Zweefparasol vs kantelparasol: wat past bij jou?</h2>
      <p>Kies een <strong>zweefparasol</strong> als je een loungestel hebt (geen centrale paal in de weg), een groot oppervlak wilt afdekken (3×3m of groter) of de zon makkelijk wilt volgen zonder op te staan.</p>
      <p>Kies een <strong>kantelparasol</strong> als je een tafel met centrale gat hebt, je budget beperkter is (kantelparasols zijn goedkoper), of je de parasol ook op een balkon wilt gebruiken.</p>
      <h2>Doek materiaal vergelijken</h2>
      <p><strong>Polyester</strong> (goedkoop): droog in ~30 min, UV40+, verkleurt na 3–4 jaar. Voldoende voor budget-parasols.</p>
      <p><strong>Olefin/Acryl</strong> (midrange): UV50+, zeer kleurecht, droogt snel. De standaard voor Doppler Expert.</p>
      <p><strong>Sunbrella</strong> (premium): UV50+, 5 jaar kleurgarantie, waterdicht behandeld, vaatwasmachinebestendig. De keuze voor Glatz en premium merken.</p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-slate-900 mb-5">Veelgestelde vragen zweefparasol</h2>
      <div class="space-y-2">
        {faqItems.map(({ q, a }) => (
          <details class="group border border-slate-200 rounded-xl bg-white overflow-hidden">
            <summary class="flex items-center justify-between px-5 py-4 font-semibold text-slate-900 cursor-pointer list-none hover:bg-slate-50 transition-colors">
              <span class="pr-4 text-sm">{q}</span>
              <span class="text-slate-300 group-open:text-green-500 text-xl leading-none shrink-0"><span class="group-open:hidden">+</span><span class="hidden group-open:inline">−</span></span>
            </summary>
            <div class="px-5 pb-4 pt-0 text-slate-600 text-sm leading-relaxed border-t border-slate-100">{a}</div>
          </details>
        ))}
      </div>
    </section>

    <section class="border-t border-slate-200 pt-8">
      <div class="flex flex-wrap gap-3">
        <a href="/beste-parasol" class="border border-slate-200 bg-white hover:border-green-400 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 transition-colors">Alle parasols →</a>
        <a href="/beste-loungeset" class="border border-slate-200 bg-white hover:border-green-400 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 transition-colors">Beste loungeset →</a>
        <a href="/terras-inrichten" class="border border-slate-200 bg-white hover:border-green-400 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 transition-colors">Terras inrichten →</a>
      </div>
    </section>
  </div>

  <StickyBuyBar
    label="Zweefparasol"
    bolUrl="https://www.bol.com/nl/nl/s/?searchtext=zweefparasol+aluminium"
    coolblueUrl="https://www.coolblue.nl/zoeken?query=zweefparasol"
  />
</Layout>
