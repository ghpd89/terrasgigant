---
import Layout from '../layouts/Layout.astro';

const faqItems = [
  { q: 'Hoe reinig je aluminium tuinmeubelen?', a: 'Was met lauwwarm water en een klein beetje afwasmiddel. Gebruik een zachte borstel of microvezeldoek. Spoel af met schoon water. Nooit schuurmiddelen of hogedrukreiniger op de coating. Jaarlijks voldoende.' },
  { q: 'Hoe behandel je teak terrasmeubelen?', a: 'Schrobben met zeepwater, 24 uur drogen. Dan schuren met 120-grit schuurpapier meewerken met de nerf. Teak-olie aanbrengen met kwast of doek, 2 lagen, drogen tussen lagen. Totaal 1–2 uur per set.' },
  { q: 'Hoe zorg je dat kussens niet schimmelen?', a: 'Bewaar kussens nooit buiten bij regen. Berg ze op in een droge kussenzak of -box. Als kussens toch nat zijn geworden: volledig laten drogen voor opslag. Schimmel verwijderen met 1:3 azijn-water oplossing en goed naspoelen.' },
  { q: 'Hoe maak je polyrattan schoon?', a: 'Spoel af met tuinslang of gebruik warm water met zeep en een zachte borstel. Werk het vlechtwerk in — vuil nestelt zich in de vlecht. Nooit schurende middelen. Laat goed drogen voor opslag.' },
];

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "BreadcrumbList", "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.terrasgigant.nl" },
      { "@type": "ListItem", "position": 2, "name": "Onderhoud terrasmeubelen", "item": "https://www.terrasgigant.nl/terrasmeubelen-onderhoud" }
    ]},
    { "@type": "FAQPage", "mainEntity": faqItems.map(({ q, a }) => ({ "@type": "Question", "name": q, "acceptedAnswer": { "@type": "Answer", "text": a } })) }
  ]
});
---

<Layout
  title="Terrasmeubelen onderhoud — per materiaal tips & schema | Terrasgigant.nl"
  description="Hoe onderhoud je terrasmeubelen? Aluminium, teak en polyrattan onderhoudstips, schema en producten per materiaal."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={structuredData} />
  </Fragment>

  <div class="max-w-5xl mx-auto px-4 py-10">
    <nav class="text-sm text-slate-500 mb-6 flex gap-2">
      <a href="/" class="hover:text-green-600">Home</a><span>›</span>
      <span class="text-slate-700">Onderhoud terrasmeubelen</span>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mb-3">Terrasmeubelen onderhoud</h1>
    <p class="text-slate-600 text-lg mb-10 max-w-2xl">Goed onderhoud verlengt de levensduur van je terrasmeubelen enorm. Per materiaal een duidelijk schema en stappenplan.</p>

    <!-- Per materiaal -->
    <section class="mb-12 space-y-6">
      {[
        {
          mat: 'Aluminium', icon: '🔩', freq: 'Begin seizoen + afsluiten',
          stappen: ['Afspoelen met tuinslang of vochtige doek', 'Vlekken verwijderen met zeepwater + zachte borstel', 'Droog afdekken met tuinhoes bij einde seizoen', 'Kussens naar binnen in winter'],
          tip: 'Nooit hogedrukreiniger op de poedercoating — dit beschadigt de laag.',
          kleur: 'bg-slate-50 border-slate-200',
        },
        {
          mat: 'Teak hout', icon: '🌳', freq: '1× per jaar (begin seizoen)',
          stappen: ['Schrobben met teakreiniger of zeepwater', '24 uur drogen in zon/wind', 'Schuren met 120-grit schuurpapier (meewerken nerf)', 'Teak-olie aanbrengen (2 lagen, 4h drogen tussendoor)', 'Alternatief: laten vergrijzen — ook duurzaam'],
          tip: 'Gebruik FSC-gecertificeerde teak-olie. Goedkope olie bevat soms oplosmiddelen die het hout beschadigen.',
          kleur: 'bg-amber-50 border-amber-200',
        },
        {
          mat: 'Polyrattan', icon: '🧺', freq: 'Begin en einde seizoen',
          stappen: ['Afspoelen met tuinslang', 'Zachte borstel voor vuil in het vlechtwerk', 'Zeepwater voor hardnekkige vlekken', 'Volledig laten drogen voor opslag', 'Kussens altijd binnenhalen'],
          tip: 'Schimmel op polyrattan: behandel met 1-delig azijn op 3-delig water. Inwerken, 10 min wachten, naspoelen.',
          kleur: 'bg-green-50 border-green-200',
        },
      ].map(({ mat, icon, freq, stappen, tip, kleur }) => (
        <div class={`border rounded-2xl overflow-hidden ${kleur}`}>
          <div class="px-6 py-4 border-b border-current/10">
            <div class="flex items-center gap-3">
              <span class="text-2xl">{icon}</span>
              <div>
                <div class="font-bold text-slate-900">{mat}</div>
                <div class="text-xs text-slate-500">{freq}</div>
              </div>
            </div>
          </div>
          <div class="px-6 py-5">
            <ol class="space-y-2 text-sm text-slate-700">
              {stappen.map((s, i) => (
                <li class="flex gap-2">
                  <span class="shrink-0 w-5 h-5 bg-green-100 text-green-700 rounded-full text-xs font-bold flex items-center justify-center">{i + 1}</span>
                  {s}
                </li>
              ))}
            </ol>
            <div class="mt-4 bg-white rounded-xl px-4 py-3 text-xs text-slate-600 border border-current/10">
              💡 <strong>Tip:</strong> {tip}
            </div>
          </div>
        </div>
      ))}
    </section>

    <!-- Kussens -->
    <section class="mb-12 bg-blue-50 border border-blue-200 rounded-2xl p-6">
      <h2 class="text-xl font-bold text-slate-900 mb-3">🧵 Kussenonderhoud — vaak onderschat</h2>
      <div class="grid sm:grid-cols-2 gap-4 text-sm text-slate-600">
        <div>
          <p class="font-semibold text-slate-800 mb-2">Gewone wasbare kussens:</p>
          <ul class="space-y-1">
            <li>✓ Was op 40°C (check label)</li>
            <li>✓ Droog liggend (niet ophangen)</li>
            <li>✓ Berg op in droge kussenzak</li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-slate-800 mb-2">Sunbrella / Olefin kussens:</p>
          <ul class="space-y-1">
            <li>✓ Reinigen met zeepwater + borstel</li>
            <li>✓ Naspoelen met schoon water</li>
            <li>✓ Kunnen vaker buiten blijven</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-slate-900 mb-5">Veelgestelde vragen onderhoud</h2>
      <div class="space-y-3">
        {faqItems.map(({ q, a }) => (
          <details class="group border border-slate-200 rounded-xl bg-white overflow-hidden">
            <summary class="flex items-center justify-between px-5 py-4 font-semibold text-slate-900 cursor-pointer list-none hover:bg-slate-50 transition-colors">
              <span class="pr-4 text-sm sm:text-base">{q}</span>
              <span class="text-slate-300 group-open:text-green-500 text-xl leading-none shrink-0 transition-colors">
                <span class="group-open:hidden">+</span><span class="hidden group-open:inline">−</span>
              </span>
            </summary>
            <div class="px-5 pb-4 pt-0 text-slate-600 text-sm leading-relaxed border-t border-slate-100">{a}</div>
          </details>
        ))}
      </div>
    </section>

    <section class="border-t border-slate-200 pt-8">
      <div class="flex flex-wrap gap-3">
        <a href="/terrasmeubelen-opbergen-winter" class="border border-slate-200 bg-white hover:border-green-400 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 transition-colors">Winteropslag →</a>
        <a href="/aluminium-terrasmeubelen" class="border border-slate-200 bg-white hover:border-green-400 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 transition-colors">Aluminium meubelen →</a>
        <a href="/teak-terrasmeubelen" class="border border-slate-200 bg-white hover:border-green-400 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 transition-colors">Teak meubelen →</a>
      </div>
    </section>
  </div>
</Layout>
